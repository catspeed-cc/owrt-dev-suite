verify_configuration


# ==============================================================================
# File Operations
# ==============================================================================

verify_md5() {
    # Parameters
    local file_src="$1"
    local file_dest="$2"

    # Local vars
    local desc="Checking MD5"

    # Calculate and sanitize hashes
    local file_src_md5=$(md5sum "$file_src" | awk '{print $1}')
    local file_dest_md5=$(md5sum "$file_dest" | awk '{print $1}')

    if [ "$file_src_md5" == "$file_dest_md5" ]; then
        local msg=" >>> ✅ Success: $desc"
        echo "$msg"
        SUMMARY_OUT+="${msg}\n"
        return 0
    else
        echo " >>>"
        echo " >>> ❌ FAILURE: $desc - MISMATCH!"
        echo " >>>      Source:      '$file_src' -> '$file_src_md5'"
        echo " >>>      Destination: '$file_dest' -> '$file_dest_md5'"
        echo " >>>"
        return 1
    fi
}

copy_file() {

    # Parameters
    local file_src="$1"
    local file_dest="$2"

    # Local variables
    local desc="Copying File"
    local dest_dir

    # Ensure source file exists or exit_with_error
    if [ ! -f "$file_src" ]; then
        exit_with_error "$desc failed: ${file_src} doesn't exist"
    fi

    # Fetch the file's directory
    dest_dir="$(dirname "$file_dest")"

    # Create directory if it doesn't exist (including parents)
    if [ ! -d "$dest_dir" ]; then
        mkdir -p "$dest_dir"
    fi

    # Remove destination file if it already exists
    if [ -f "$file_dest" ]; then
        rm "$file_dest"
    fi

    # Copy file
    if ! cp "$file_src" "$file_dest"; then
        exit_with_error "$desc failed: ${file_dest}"
    fi

    # Verify md5 & output messages
    if verify_md5 "$file_src" "$file_dest"; then
	local msg=" >>> ✅ Success: $desc (MD5 matches)"
        echo "$msg"
        SUMMARY_OUT+="${msg}"$'\n'
        return 0
    else
        exit_with_error "$desc failed (MD5 mismatch)"
        return 1 # pragmatic safety: this shouldn't execute
    fi

}

copy_patches_dir() {
    # Parameters
    local dir_src="$1"
    local dir_dest="$2"

    echo " >>> Copying Patches Directory ${dir_src}"

    # Check if source directory exists
    if [ ! -d "${dir_src}" ]; then
        exit_with_error "Source directory does not exist: ${dir_src}"
    fi

    # Check if destination directory exists
    if [ ! -d "${dir_dest}" ]; then
        exit_with_error "Destination directory does not exist: ${dir_dest}"
    fi

    # Loop over each .patch file non-recursively and copy using your function
    for src_file in "${dir_src}"/*.patch; do

        # Check if glob matched any files (handles empty directory case)
        [ -e "$src_file" ] || continue

        # Extract just the filename for the destination
        filename="$(basename "$src_file")"
        dest_file="${dir_dest}/${filename}"

        # Use your existing copy_file function
        copy_file "$src_file" "$dest_file"

    done

    echo " >>> ✅ Patches Directory Copied ${dir_src}"
    SUMMARY_OUT+=" >>> ✅ Patches Directory Copied ${dir_src}"$'\n'

}

copy_caldata() {

    FIRMWARE_BUILD_DIR=$(find "$DEV_DIR/build_dir" -type d -name "linux-firmware-*" | head -n 1)

    if [ -n "$FIRMWARE_BUILD_DIR" ]; then

        # QCA9984
        DEST_FW="$FIRMWARE_BUILD_DIR/ath10k/QCA9984/hw1.0"

        copy_file "$QCA9984_FIRMWARE" "$DEST_FW/board-2.bin" || exit_with_error "Copy Caldata"

        echo ">>> QCA9984 board-2.bin copied to: $DEST_FW"


        # QCA4019
        DEST_FW="$FIRMWARE_BUILD_DIR/ath10k/QCA4019/hw1.0"

        copy_file "$QCA4019_FIRMWARE" "$DEST_FW/board-2.bin" || exit_with_error "Copy Caldata"

        echo ">>> QCA4019 board-2.bin copied to: $DEST_FW"

    else

        exit_with_error "Could not find linux-firmware build directory after prepare."

    fi

}


# ==============================================================================
# Build Operations
# ==============================================================================

build_kernel_sources() {

    # Download sources (Prerequisite)
    echo ">>> Running 'make download'..."
    make download ${MAKE_CMD_ADD} || exit_with_error "Make Download"

    # Copy custom patches into the target directory
    # These will be picked up automatically by the 'prepare' step

    if [ "$DO_PATCHMOD" = true ]; then

        if [ -z "${PATCHES_DEST_DIR}" ]; then
            exit_with_error "PATCHES_DEST_DIR is not set (check script config)"
        fi

        IPQESS_MOD_H_SRC="${IPQESS_MOD_SRC_DIR}/ipqess.h.modified"
        IPQESS_MOD_C_SRC="${IPQESS_MOD_SRC_DIR}/ipqess.c.modified"
        IPQESS_MOD_ETHTOOL_C_SRC="${IPQESS_MOD_SRC_DIR}/ipqess_ethtool.c.modified"

        IPQESS_MOD_H_DEST="${IPQESS_MOD_DEST_DIR}/ipqess.h"
        IPQESS_MOD_C_DEST="${IPQESS_MOD_DEST_DIR}/ipqess.c"
        IPQESS_MOD_ETHTOOL_C_DEST="${IPQESS_MOD_DEST_DIR}/ipqess_ethtool.c"

        if [ "$DO_RAWMOD" != true ]; then

            # Applies the driver patches
            copy_patches_dir "${PATCHES_SRC_DIR}" "${$PATCHES_DEST_DIR}"

            echo " >>> ✅ DRIVER PATCHES copied to source tree: $PATCHES_SRC_DIR"
            SUMMARY_OUT+=" >>> ✅ DRIVER PATCHES copied to source tree: $PATCHES_SRC_DIR"$'\n'

        else

            # Applies the raw driver mod source
            copy_file "$IPQESS_MOD_H_SRC" "$IPQESS_MOD_H_DEST" || exit_with_error "Copying Driver Mod (ipqess.h)"
            copy_file "$IPQESS_MOD_C_SRC" "$IPQESS_MOD_C_DEST" || exit_with_error "Copying Driver Mod (ipqess.c)"
            copy_file "$IPQESS_MOD_ETHTOOL_C_SRC" "$IPQESS_MOD_ETHTOOL_C_DEST" || exit_with_error "Copying Driver Mod (ipqess_ethtool.c)"

            echo ">>> ✅ IPQESS RAW DRIVER MOD copied to source tree: $IPQESS_MOD_DEST_DIR"
            SUMMARY_OUT+=" >>> ✅ IPQESS RAW DRIVER MOD APPLIED: $IPQESS_MOD_DEST_DIR"$'\n'

        fi

    fi

    # Prepare (Extract + Apply Patches)
    echo ">>> Running 'make target/linux/prepare'..."
    make target/linux/prepare ${MAKE_CMD_ADD} || exit_with_error "Make Prepare `linux`"
    echo ">>> Sources prepared with custom patches applied."

    # Compile
    echo ">>> Running 'make target/linux/compile'..."
    make target/linux/compile ${MAKE_CMD_ADD} || exit_with_error "Make Compile `linux`"
    echo ">>> Sources compiled with custom patches applied."

}

do_final_build() {

    MAKE_CMD="make ${MAKE_CMD_ADD}"
    echo ">>> Starting compilation: ${MAKE_CMD}"
    $MAKE_CMD

    if [ $? -eq 0 ]; then

        # clobber the image out old files
        rm -rf "${IMG_OUT_DEST}"*

        # copy the new files
        cp -r "${IMG_OUT_SRC}"* "$IMG_OUT_DEST"

        echo " >>> ✅ IMAGES COPIED TO WORK DIR: $IMG_OUT_DEST"
        SUMMARY_OUT="${SUMMARY_OUT}"$'\n'" >>> ✅ IMAGES COPIED TO WORK DIR: $IMG_OUT_DEST"

        exit_with_success

    else

        exit_with_error "BUILD FAILED"

    fi

}




# ==============================================================================
# Execution Preperation
# ==============================================================================

# HANDLE MAKE COMMAND BUILDING HERE
# WE NEED IT THROUGHOUT REST OF CODE

# Handle Concurrency
if [ "$DO_SLOW" = false ]; then
    NUM_PROC=$(nproc)
    MAKE_CMD_ADD="${MAKE_CMD_ADD}-j${NUM_PROC}"
else
    MAKE_CMD_ADD="${MAKE_CMD_ADD}-j1"
fi

# Handle Verbosity
if [ "$DO_VERBOSE" = true ]; then
    MAKE_CMD_ADD="${MAKE_CMD_ADD} V=s"
elif [ "$DO_XVERBOSE" = true ]; then
    MAKE_CMD_ADD="${MAKE_CMD_ADD} V=99"
fi


# ==============================================================================
# Execution Logic
# ==============================================================================

echo ">>> Starting Build Process for TEW-829DRU (IPQ4019)"
echo ">>> Working Directory: $DEV_DIR"
cd "$DEV_DIR" || exit 1

# Handle Clean
if [ "$DO_CLEAN" = true ]; then
    echo ">>> Running 'make clean'..."
    make clean
fi

# Handle Update Feeds (First, to ensure package definitions are fresh)
if [ "$DO_UPDATE_FEEDS" = true ]; then
    echo ">>> Updating and installing feeds..."
    ./scripts/feeds update -a
    ./scripts/feeds install -a
fi

# Handle Inject DTS (BEFORE prepare)
if [ "$DO_DTS_CPY" = true ]; then
    echo ">>> Injecting custom DTS file..."
    if copy_file "$DTS_SRC" "$DTS_DEST"; then
        echo ">>> ✅ DTS copied to source tree: $DTS_DEST"
        SUMMARY_OUT+=" >>> ✅ DTS COPIED: $DTS_DEST"$'\n'
    fi
fi

# Handle Prepare Kernel Sources
if [ "$DO_CLEAN" = true ]; then
    build_kernel_sources
fi

# Handle prepare linux-firmware
if [ "$DO_CLEAN" = true ]; then
    echo ">>> Running 'make target/linux-firmware/prepare'..."
    make package/linux-firmware/prepare ${MAKE_CMD_ADD} || exit_with_error "Make Prepare `linux-firmware`"
    echo ">>> Sources prepared."
fi

# Handle Copy caldata
if [ "$DO_CALDATA_CPY" = "true" ]; then
    echo ">>> Injecting board-2.bin into build_dir..."
    copy_caldata
fi

# PAUSE SO USER CAN SEE PROGRESS BEFORE COMPILE
sleep 5




# Compile
do_final_build




