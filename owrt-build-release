# ============================================
# NOTE: DO NOT CONFIGURE ANYTHING IN THIS FILE
# Edit `./etc/config.sh` to configure
# ============================================


# NOTICE: THIS IS REQUIRED FOR SCRIPT! DO NOT REMOVE!
#
# REASONS:
# - Script is heavy in file operations
# - One unbound variable within a derived path can mangle an undesired location
# - I need to see and know when something is unbound and fix it
set -Eeuo pipefail

# Version Information
OWRTDS_VERSION="v0.1.0"

# Guard variable to prevent double cleanup
CLEANED=false

BUILD_START_DATE=$(date "+%a %d %b %Y")
BUILD_START_TIME=$(date +%H:%M:%S)

# Populated at the end of script
BUILD_STOP_DATE=""
BUILD_STOP_TIME=""
BUILD_ELAPSED=""

# REQUIRED FOR SOURCE LINES (DO NOT MODIFY)
REAL_PATH=$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null)
# Fallback for macOS (BSD readlink doesn't support -f)
if [ -z "$REAL_PATH" ]; then
    REAL_PATH="${BASH_SOURCE[0]}"
    while [ -h "$REAL_PATH" ]; do
        DIR=$(cd -P "$(dirname "$REAL_PATH")" && pwd)
        REAL_PATH=$(readlink "$REAL_PATH")
        [[ $REAL_PATH != /* ]] && REAL_PATH="$DIR/$REAL_PATH"
    done
    # Final resolve of the last step if it wasn't a symlink loop
    [ -e "$REAL_PATH" ] && REAL_PATH=$(cd -P "$(dirname "$REAL_PATH")" && pwd)/$(basename "$REAL_PATH")
fi

# REQUIRED FOR SOURCE LINES (DO NOT MODIFY)
SCRIPT_DIR=$(dirname "$REAL_PATH")
SCRIPT_NAME=$(basename "$REAL_PATH")

# Set up for infinite strings (NEEDED IN `lib/config.sh`)
NL=$'\n' # leave this alone (used in multiple areas)

# Flags default values (safe defaults)
DO_CLEAN=false
DO_UPDATE_FEEDS=false
DO_VERBOSE=false
DO_XVERBOSE=false
DO_SLOW=false

# ====================================================================================
# TO AVOID FAILURE IN `set -euo pipefail` MODE DEFINE USER VARIABLES WHICH ARE EITHER:
#  - only user defined in lib/config.sh
#  - derived from user defined but user overrideable in lib/config.sh
# Internal/Derived only variables will remain defined inline where used
# ====================================================================================
#
# DO NOT MANUAL EDIT THESE - THEY ARE DEFAULTS. USER EDITS IN `etc/config.sh`.
#
# USER CONFIG VARIABLES (DEFAULTS)
#
OWRT_REMOTE_ALIAS="catspeed-cc"
OWRT_FORK_REPO="https://github.com/catspeed-cc/openwrt.git"
OWRT_BASE_BRANCH="25.12"
OWRT_TARGET_BRANCH="tew-829dru-25.12"
DEVICE_SUPPORTED="true"
ENABLE_SYMLINK_SHORTCUTS="true"

OWRT_MFR="TRENDnet"
OWRT_MODEL="TEW-829DRU"
OWRT_SOC="ipq4019"
OWRT_SOC_CLASS="ipq40xx"
OWRT_OS_TARGET="linux"

OWRT_MFR_LOWER=""
OWRT_MODEL_LOWER=""
OWRT_SOC_LOWER=""
OWRT_SOC_CLASS_LOWER=""
OWRT_OS_TARGET_LOWER=""

WORK_DIR="$HOME/work"
PROJECT_DIR="$HOME/projects"
OWRT_DEV_DIR="$PROJECT_DIR/openwrt-dev"
IMGDIR_SRC="$OWRT_DEV_DIR/bin/targets/ipq40xx/generic"

SUDO_ENABLE="false"

WORK_DTS_DIR="$WORK_DIR/ipq40xx/trendnet/tew-829dru/dts"
WORK_CALDATA_DIR="$WORK_DIR/ipq40xx/trendnet/tew-829dru/caldata"
WORK_PATCHMODS_DIR="$WORK_DIR/ipq40xx/trendnet/tew-829dru/patchmods"
WORK_RAWMODS_DIR="$WORK_DIR/ipq40xx/trendnet/tew-829dru/rawmods"
WORK_IMAGEOUT_DIR="$WORK_DIR/ipq40xx/trendnet/tew-829dru/image-out"

DO_DTS_CPY="false"
DTS_FNAME=""
DTS_DEST_DIR="$OWRT_DEV_DIR/target/linux/ipq40xx/files-6.12/arch/arm/boot/dts/qcom"

DO_IMGDIR_CPY="true"

DO_WEBSERVER_CPY="false"
WEBSERVER_USER="www-data"
WEBDIR_DEST="/srv/openwrt-builds/"

DO_DRIVERMOD_CPY="false"
DRIVERMOD_MODE="patchmod"
PATCHMOD_DEST_DIR="target/linux/ipq40xx/patches-6.12/"
RAWMOD_LIST=""

DO_CALDATA_CPY="false"
CALDATA_LIST=""

# ====================================================================================

# Required to start blank/empty
SUMMARY_OUT=""
MAKE_CMD_ADD=""

# Ensure STARTUP_PWD does not have a trailing slash for consistent matching
STARTUP_PWD=$(pwd)
STARTUP_PWD="${STARTUP_PWD%/}"

# Import config
if ! source "$SCRIPT_DIR/etc/config.sh"; then
    echo "❌ CRITICAL: Unable to source etc/config.sh - Aborting." >&2
    exit 1
fi

# Import dependencies
if ! source "$SCRIPT_DIR/lib/dependencies.sh"; then
    echo "❌ CRITICAL: Unable to source lib/dependencies.sh - Aborting." >&2
    exit 1
fi

# Import functions
if ! source "$SCRIPT_DIR/lib/functions.sh"; then
    echo "❌ CRITICAL: Unable to source lib/functions.sh - Aborting." >&2
    exit 1
fi


# ===========================================================================================
# verify config - vars above this point must not use eachother (EXCEPT CRITICAL startup vars)
# ===========================================================================================
verify_configuration
# ===========================================================================================
# verify config - vars below this point can use each other to autoconfigure
# ===========================================================================================

# Ensure we go to our script location (owrt-dev-suite repo)
cd "$REAL_PATH"

# Get the git branch for display
GIT_BRANCH=$(cd "$SCRIPT_DIR" && git branch --show-current)
# Fallback for detached HEAD or old git versions
if [ -z "$GIT_BRANCH" ]; then
    GIT_BRANCH=$(cd "$SCRIPT_DIR" && git rev-parse --abbrev-ref HEAD)
fi

# Ensure we go back to the original PWD before build
cd "$STARTUP_PWD"

# Show the pretty header
show_header

# Parse the arguments (overrides config)
parse_arguments "$@"

# Install dependencies
install_dependencies




# ==============================================================================
# Execution Preperation
# ==============================================================================

# Ensure we go back to the original PWD before build
cd "$STARTUP_PWD"

# Handle Concurrency
if [ "$DO_SLOW" = false ]; then
    NUM_PROC=$(nproc)
    MAKE_CMD_ADD="${MAKE_CMD_ADD}-j${NUM_PROC}"
else
    MAKE_CMD_ADD="${MAKE_CMD_ADD}-j1"
fi

# Handle Verbosity
if [ "$DO_VERBOSE" = true ]; then
    MAKE_CMD_ADD="${MAKE_CMD_ADD} V=s"
elif [ "$DO_XVERBOSE" = true ]; then
    MAKE_CMD_ADD="${MAKE_CMD_ADD} V=99"
fi

# Register the trap ONLY for interruption signals (INT, TERM, HUP)
# Do NOT trap EXIT here; let your wrappers handle normal exits.
# Define specific handlers for each signal to pass the name correctly
trap 'exit_with_error "Caught by trap - user pressed CTRL+C (SIGINT). Aborting."' INT
trap 'exit_with_error "Caught by trap - script terminated (SIGTERM). Aborting."' TERM
trap 'exit_with_error "Caught by trap - connection hung up (SIGHUP). Aborting."' HUP
# we skipped my idea of using a trap exit handler - neat!

# ==============================================================================
# Execution Logic
# ==============================================================================

echo " >>> Starting Build Process for TEW-829DRU (IPQ4019)"
echo " >>> Working Directory: $OWRT_DEV_DIR"
cd "$OWRT_DEV_DIR" || exit 1

# Handle Clean
if [ "$DO_CLEAN" = true ]; then
    echo " >>> Running 'make clean'..."
    make clean
    msg=" >>> ✅ Make clean"
    echo "$msg"
    SUMMARY_OUT+="${msg}"${NL}
fi

# Handle Update Feeds (First, to ensure package definitions are fresh)
if [ "$DO_UPDATE_FEEDS" = true ]; then
    echo " >>> Updating and installing feeds..."
    ./scripts/feeds update -a
    ./scripts/feeds install -a
    msg=" >>> ✅ Feeds updated & installed"
    echo "$msg"
    SUMMARY_OUT+="${msg}"${NL}
fi

# Handle Inject DTS (BEFORE prepare)
if [ "$DO_DTS_CPY" = true ]; then
    echo " >>> Injecting custom DTS file..."
    copy_file "$WORK_DTS_DIR/$DTS_FNAME" "$DTS_DEST_DIR/$DTS_FNAME"
fi

# Handle Prepare Kernel Sources
if [ "$DO_CLEAN" = true ]; then
    build_kernel_sources
fi

# Handle prepare linux-firmware
if [ "$DO_CLEAN" = true ]; then
    echo " >>> Running 'make target/linux-firmware/prepare'..."
    make package/linux-firmware/prepare ${MAKE_CMD_ADD} || exit_with_error "Make Prepare `linux-firmware`"
    msg=" >>> ✅ Sources prepared (linux-firmware)"
    echo "$msg"
    SUMMARY_OUT+="${msg}"${NL}
fi

# Handle Copy caldata
if [ "$DO_CALDATA_CPY" = "true" ]; then
    echo " >>> Injecting board-2.bin into build_dir..."
    copy_caldata
fi




# ===============
#   FINAL BUILD
# ===============

# PAUSE SO USER CAN SEE PROGRESS BEFORE COMPILE
sleep 5

# Compile
MAKE_CMD="make ${MAKE_CMD_ADD}"
echo " >>> Starting compilation: ${MAKE_CMD}"
$MAKE_CMD
BUILD_STATUS=$?

# UNSET THE CLEANUP TRAP - WE DO IT MANUAL (output appearance)
trap - INT TERM HUP
set +e

# Immediately copy images on success or exit_with_error on failure
if [ $BUILD_STATUS -eq 0 ]; then
    # Handle Copy images to IMGDIR_DEST
    if [ "$DO_IMGDIR_CPY" = "true" ]; then
        copy_to_imgdir
    fi
    # Handle Copy images to webserver
    if [ "$DO_WEBSERVER_CPY" = "true" ]; then
        copy_to_webserver
    fi
else
    exit_with_error "BUILD FAILED"
fi

# Gated final manual cleanup on success
if [ "$CLEANED" == false ]; then
    # clean up our patches and modified driver
    # so we don't poison commits unintentionally
    cleanup_build_environment
fi

# Calculate time elapsed
BUILD_STOP_DATE=$(date "+%a %d %b %Y")
BUILD_STOP_TIME=$(date +%H:%M:%S)

BUILD_ELAPSED=$(get_time_diff "$BUILD_START_TIME" "$BUILD_STOP_TIME")

# Call final exit outside so cleanup output lines up visually :)
exit_with_success
