# ============================================
# NOTE: DO NOT CONFIGURE ANYTHING IN THIS FILE
# Edit `./etc/config.sh` to configure
# ============================================


# NOTICE: THIS IS REQUIRED FOR SCRIPT! DO NOT REMOVE!
#
# REASONS:
# - Script is heavy in file operations
# - One unbound variable within a derived path can mangle an undesired location
# - I need to see and know when something is unbound and fix it
set -Eeuo pipefail

# Ensure STARTUP_PWD does not have a trailing slash for consistent matching
STARTUP_PWD=$(pwd)
STARTUP_PWD="${STARTUP_PWD%/}"

# REQUIRED FOR SOURCE LINES (DO NOT MODIFY)
REAL_PATH=$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null)

# Fallback for macOS (BSD readlink doesn't support -f)
if [ -z "$REAL_PATH" ]; then
    REAL_PATH="${BASH_SOURCE[0]}"
    while [ -h "$REAL_PATH" ]; do
        DIR="$(dirname "$REAL_PATH")"
        # Check if directory exists before cd-ing
        if [ ! -d "$DIR" ]; then
            echo "❌ CRITICAL: Directory does not exist: $DIR" >&2
            exit 1
        fi
        DIR=$(cd -P "$DIR" && pwd)

        REAL_PATH=$(readlink "$REAL_PATH")
        [[ $REAL_PATH != /* ]] && REAL_PATH="$DIR/$REAL_PATH"
    done

    # Final resolve of the last step if it wasn't a symlink loop
    if [ -e "$REAL_PATH" ]; then
        DIR="$(dirname "$REAL_PATH")"
        # Check if directory exists before cd-ing
        if [ ! -d "$DIR" ]; then
            echo "❌ CRITICAL: Directory does not exist: $DIR" >&2
            exit 1
        fi
        REAL_PATH=$(cd -P "$DIR" && pwd)/$(basename "$REAL_PATH")
    fi
fi

# REQUIRED FOR SOURCE LINES (DO NOT MODIFY)
SCRIPT_DIR=$(dirname "$REAL_PATH")
SCRIPT_NAME=$(basename "$REAL_PATH")


# Import lib/common.sh
if ! source "$SCRIPT_DIR/lib/common.sh"; then
    echo "❌ CRITICAL: Unable to source lib/common.sh - Aborting." >&2
    exit 1
fi




# ==============================================================================
# 1. Execution Logic
# ==============================================================================

echo " >>> Starting build process for $OWRT_MFR / $OWRT_MODEL_LOWER (${OWRT_SOC_CLASS_LOWER})"
echo " >>> Working directory: $OWRT_DEV_DIR"
change_directory "$OWRT_DEV_DIR"

# Handle Clean
if [[ "$DO_CLEAN" == "true" ]]; then
    echo " >>> Running 'make clean'..."
    if [[ "$OWRTDS_INTERACTIVE" == "true" ]]; then
        rm -rf "$OWRT_DEV_DIR/build_dir" 2>&1
        rm -rf "$OWRT_DEV_DIR/staging_dir" 2>&1
        log_summary " >>> ✅ Make clean"
    else
        make clean -s > /dev/null 2>&1
        rm -rf "$OWRT_DEV_DIR/build_dir" 2>&1
        rm -rf "$OWRT_DEV_DIR/staging_dir" 2>&1
    fi
fi

# Handle Update Feeds (First, to ensure package definitions are fresh)
if [[ "$DO_UPDATE_FEEDS" == "true" ]]; then
    echo " >>> Updating and installing feeds..."
    if [[ "$OWRTDS_INTERACTIVE" == "true" ]]; then
        ./scripts/feeds update -a
        ./scripts/feeds install -a
        log_summary " >>> ✅ Feeds updated & installed"
    else
        ./scripts/feeds update -a > /dev/null 2>&1
        ./scripts/feeds install -a > /dev/null 2>&1
    fi
fi

if [[ "$DO_CLEAN" == "true" ]]; then
    echo " >>> Ensuring host tools and toolchain are ready..."
    if [[ "$OWRTDS_INTERACTIVE" == "true" ]]; then
        make tools/install ${MAKE_CMD_ADD} || exit_with_error "Failed to build host tools"
        make toolchain/install ${MAKE_CMD_ADD} || exit_with_error "Failed to build toolchain"
        log_summary " >>> ✅ Toolchain built"
    else
        make tools/install ${MAKE_CMD_ADD} > /dev/null 2>&1 || exit_with_error "Failed to build host tools"
        make toolchain/install ${MAKE_CMD_ADD} > /dev/null 2>&1 || exit_with_error "Failed to build toolchain"
    fi
fi

# Handle Inject DTS (BEFORE prepare)
if [[ "$DEVICE_SUPPORTED" == "false" && "$DO_DTS_CPY" == "true" && "$DO_CLEAN" == "true" ]]; then
    echo " >>> Injecting custom DTS file..."
    copy_file "$WORK_DTS_DIR/$DTS_FNAME" "$DTS_DEST_DIR/$DTS_FNAME"
    # Prepare Kernel Sources
    if [[ "$OWRTDS_INTERACTIVE" == "true" ]]; then
        build_kernel_sources
        log_summary " >>> ✅ Kernel source built"
    else
        build_kernel_sources
    fi
fi

# Handle prepare linux-firmware
if [[ "$DEVICE_SUPPORTED" == "false" && "$DO_CALDATA_CPY" == "true" && "$DO_CLEAN" == "true" ]]; then
    echo " >>> Running 'make target/linux-firmware/prepare'..."
    if [[ "$OWRTDS_INTERACTIVE" == "true" ]]; then
        make package/linux-firmware/prepare ${MAKE_CMD_ADD} || exit_with_error "Make Prepare 'linux-firmware'"
        log_summary " >>> ✅ Sources prepared (linux-firmware)"
    else
        make package/linux-firmware/prepare ${MAKE_CMD_ADD} > /dev/null 2>&1 || exit_with_error "Make Prepare 'linux-firmware'"
    fi
    # Handle Copy caldata
    echo " >>> Injecting board-2.bin into build_dir..."
    copy_caldata
fi




# ==============================================
# 2. COMPILATION & POST-BUILD
# ==============================================

# PAUSE SO HUMAN USER CAN SEE PROGRESS BEFORE COMPILE
if [[ "$OWRTDS_INTERACTIVE" == true ]]; then sleep 5; fi

# 1. Temporarily disable 'errexit' to capture make's exit code manually.
#    NOTE: The SIGINT/SIGTERM trap remains ACTIVE here for CTRL+C safety.
set +e

# Now the main build can proceed without host tool interruptions
MAKE_CMD="make ${MAKE_CMD_ADD}"
echo " >>> Starting compilation: ${MAKE_CMD}"
if [[ "$OWRTDS_INTERACTIVE" == "true" ]]; then
    $MAKE_CMD
    BUILD_STATUS=$?
else
    $MAKE_CMD > /dev/null 2>&1
    BUILD_STATUS=$?
fi

# 2. Re-enable strict error checking immediately.
#    Any failure in copy/cleanup steps will now trigger the trap & cleanup.
set -e

# Synchronize final .config state back to work directory (runs unconditionally)
sync_config_from_dev_dir

# 3. Handle Build Result
if [ "$BUILD_STATUS" -eq 0 ]; then
    log_summary " >>> ✅ Build successful. Copying images..."

    # Run post-build steps (Trap is ACTIVE: failures here will cleanup)
    if [ "$DO_IMGDIR_CPY" = "true" ]; then
        copy_to_imgdir
    fi

    if [ "$DO_WEBSERVER_CPY" = "true" ]; then
        copy_to_webserver
    fi

    # Gated final manual cleanup on success
    if [ "$CLEANED" == false ]; then
        cleanup_build_environment
    fi

    # Calculate time elapsed
    BUILD_STOP_DATE=$(date "+%a %d %b %Y")
    BUILD_STOP_TIME=$(date +%H:%M:%S)
    result=$(get_time_diff "$BUILD_START_TIME" "$BUILD_STOP_TIME")

    # separate the reply into human readable and machine readable elapsed times
    BUILD_ELAPSED=$(echo "$result" | awk '{print $1, $2, $3}') # "0h 10m 28s"
    BUILD_ELAPSED_SECONDS=$(echo "$result" | awk '{print $4}') # "628"

    # 4. Success: Disable trap manually to prevent "Cleanup called" message on exit
    trap - INT TERM HUP
    exit_with_success "BUILD COMPLETE"
else
    # 5. Failure: Trigger error handler (Trap will also fire if set -e catches a downstream error)
    exit_with_error "BUILD FAILED (Status: $BUILD_STATUS)"
fi
