# NOTE: DO NOT CONFIGURE ANYTHING IN THIS FILE
# Edit `./etc/config.sh` to configure
# ============================================


# NOTICE: THIS IS REQUIRED FOR SCRIPT! DO NOT REMOVE!
#
# REASONS:
# - Script is heavy in file operations
# - One unbound variable within a derived path can mangle an undesired location
# - I need to see and know when something is unbound and fix it
set -Eeuo pipefail

# Ensure STARTUP_PWD does not have a trailing slash for consistent matching
STARTUP_PWD=$(pwd)
STARTUP_PWD="${STARTUP_PWD%/}"

# REQUIRED FOR SOURCE LINES (DO NOT MODIFY)
REAL_PATH=$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null)

# Fallback for macOS (BSD readlink doesn't support -f)
if [ -z "$REAL_PATH" ]; then
    REAL_PATH="${BASH_SOURCE[0]}"
    while [ -h "$REAL_PATH" ]; do
        DIR="$(dirname "$REAL_PATH")"
        # Check if directory exists before cd-ing
        if [ ! -d "$DIR" ]; then
            echo "❌ CRITICAL: Directory does not exist: $DIR" >&2
            exit 1
        fi
        DIR=$(cd -P "$DIR" && pwd)

        REAL_PATH=$(readlink "$REAL_PATH")
        [[ $REAL_PATH != /* ]] && REAL_PATH="$DIR/$REAL_PATH"
    done

    # Final resolve of the last step if it wasn't a symlink loop
    if [ -e "$REAL_PATH" ]; then
        DIR="$(dirname "$REAL_PATH")"
        # Check if directory exists before cd-ing
        if [ ! -d "$DIR" ]; then
            echo "❌ CRITICAL: Directory does not exist: $DIR" >&2
            exit 1
        fi
        REAL_PATH=$(cd -P "$DIR" && pwd)/$(basename "$REAL_PATH")
    fi
fi

# REQUIRED FOR SOURCE LINES (DO NOT MODIFY)
SCRIPT_DIR=$(dirname "$REAL_PATH")
SCRIPT_NAME=$(basename "$REAL_PATH")


# Import lib/common.sh
if ! source "$SCRIPT_DIR/lib/common.sh"; then
    echo "❌ CRITICAL: Unable to source lib/common.sh - Aborting." >&2
    exit 1
fi




# ==============================================================================
# 1. Execution Logic
# ==============================================================================

for config_file in "$SCRIPT_DIR"/etc/*/*.build; do
    [[ -f "$config_file" ]] || continue

    # Reset variables, source config, verify...
    reset_config_variables

    # Attempt to source the config
    if source "$config_file"; then
        log_summary " >>> ✅ Loaded config: $(basename "$config_file")"
    else
        log_summary " >>> ❌ FAILED to load config: $(basename "$config_file"). Skipping."
        continue
    fi

    # CHECK FLAG FIRST: Skip if not marked for batch build
    # (Using your current variable name, though OWRTDS_ENABLE_BATCH_BUILD is clearer)
    if [[ "$OWRTDS_ENABLE_BATCH_BUILD" != "true" ]]; then
        # Optional: Add a debug log if you want to see skipped files
        log_summary " >>> ⏭️  Skipping $(basename "$config_file"): Not enabled for batch build."
        continue
    fi

    # Just verify the config, it is meant to be built. The function handles failure via exit_with_error
    verify_configuration

    log_summary "🚀 Starting build: $(basename "$config_file")"

    # Run the main script (pass in parameters from user, force non-interactive, ignoring --config/-c)
    "$SCRIPT_DIR"/owrt-build-release --config "$config_file" "$@" -ni

    # 4. The "Escape Hatch" (Interactive Only)
    if [[ "$OWRTDS_INTERACTIVE" == "true" ]]; then
        echo ""
        echo "⏸️  Build step finished."
        echo "    Press Ctrl+C now to EXIT the entire batch script."
        echo "    (Wait 2 seconds to continue to the next config...)"

        # If user hits Ctrl+C here, this script dies immediately.
        # If they wait, the loop continues.
        sleep 2
    fi
done

exit_with_success " >>> ✅  SUCCESS: BATCH PROCESS COMPLETE!"
